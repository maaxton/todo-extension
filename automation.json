{
  "triggers": [
    {
      "key": "todo_created",
      "label": "Todo created",
      "output": ["todo_id", "title", "priority"]
    },
    {
      "key": "todo_completed",
      "label": "Todo completed",
      "output": ["todo_id", "title"]
    },
    {
      "key": "todo_overdue",
      "label": "Todo became overdue",
      "output": ["todo_id", "title", "due_date", "days_overdue"]
    }
  ],
  "actions": [
    {
      "key": "create_todo",
      "label": "Create a todo",
      "fields": [
        {"key": "title", "type": "text", "required": true},
        {"key": "description", "type": "text"},
        {"key": "priority", "type": "select", "options": ["low", "medium", "high", "urgent"]},
        {"key": "due_date", "type": "date"}
      ]
    },
    {
      "key": "complete_todo",
      "label": "Complete a todo",
      "description": "Mark a pending todo as complete",
      "fields": [
        {"key": "todo_id", "type": "select", "label": "Todo", "required": true, "source": "/api/extensions/todo-extension/automation/todos/pending"}
      ]
    }
  ]
}
